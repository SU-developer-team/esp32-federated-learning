@startuml
title ecdh.cpp overview

' ---- setup()/loop() ----
start
:setup();
:Serial.begin + WiFi.begin;
while (WiFi.status != WL_CONNECTED?) is (no)
  :delay + print ".";
endwhile (yes)
:Print IP;
:Wait GPIO2 HIGH;
:tls13_like_kex(key96);
if (kex ok?) then (yes)
  :Print [HS] DONE;
else (no)
  :Print [HS] FAILED;
endif
:loop();
:Reconnect WiFi and print IP (repeats forever);
stop

newpage

title tls13_like_kex()

start
:rng_init_once();
if (rng ok?) then (yes)
else (no)
  :return false (RNG fail);
  stop
endif
:TCP connect;
if (connect ok?) then (yes)
else (no)
  :return false (connect fail);
  stop
endif
:derive_psk_device = HMAC(MASTER_KEY, DEVICE_ID);
if (psk ok?) then (yes)
else (no)
  :return false (psk fail);
  stop
endif
:ECDH P-256 keypair;
:Build CH_wo_tag;
:CH tag = HMAC(PSK, CH);
:Send CH + tag;
:Read ServerHello;
:Rebuild SH_wo_tag;
:Expected SH tag = HMAC(PSK, CH||SH);
if (SH tag ok?) then (yes)
else (no)
  :return false (SH auth fail);
  stop
endif
:TH = SHA256(CH||SH);
:Parse pubB;
:Compute shared secret;
:salt = SHA256(client_random||server_random);
:info = "session-v1" || TH;
:HKDF -> srv_finished, cli_finished, key96;
:Read ServerFinished;
:Verify HMAC(srv_finished, TH);
if (SF ok?) then (yes)
else (no)
  :return false (ServerFinished fail);
  stop
endif
:Send ClientFinished;
:Print debug + return true;
stop
@enduml
